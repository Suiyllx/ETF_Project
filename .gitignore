# ── 敏感配置（绝对不能提交）────────────────────────────────────
config.py
.flask_secret
*.env
.env.*

# ── Python ──────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
build/

# ── 数据文件（体积大，用 Git LFS 或不追踪）──────────────────────
quant/data/historical/*.parquet
quant/models/saved/*.pkl
reports/*.csv

# ── 运行时生成文件 ───────────────────────────────────────────────
logs/
*.log
*.jsonl

# ── 用户数据（隐私）─────────────────────────────────────────────
portfolios/*.json

# ── 前端构建产物 ─────────────────────────────────────────────────
frontend/dist/
frontend/node_modules/
frontend/.vite/
frontend/vite.config.js.timestamp-*

# ── 系统文件 ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user
# ── 信号运行时文件（环境独立，不同步）──────────────────────────
quant/signals/candidates.json
quant/signals/thresholds.json
quant/signals/paper_trades.json
quant/signals/history/
# model_config.json 含黑名单/阈值，入库以便多环境同步
# quant/signals/model_config.json
